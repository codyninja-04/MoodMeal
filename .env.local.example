NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ANTHROPIC_API_KEY=

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Phase 3: monetization ---

# Food-delivery affiliate IDs (optional). Without them, delivery buttons still
# link to the platforms, just unattributed.
NEXT_PUBLIC_GRABFOOD_AFFILIATE_ID=
NEXT_PUBLIC_DELIVEROO_AFFILIATE_ID=

# White-label branding (optional). Defaults to MoodMeal when unset.
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_TAGLINE=
NEXT_PUBLIC_BRAND_EMOJI=
NEXT_PUBLIC_BRAND_ACCENT_RGB=        # e.g. "255 107 74"
NEXT_PUBLIC_BRAND_ACCENT_HEX=        # e.g. "#ff6b4a"

# Premium billing (optional). When wired, the upgrade flow should create a
# Stripe Checkout session and a webhook flips profiles.is_premium.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
